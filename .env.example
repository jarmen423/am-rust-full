# workspace-server (see src/server/config.rs)
PORT=3031
WORKSPACE_STORE_PATH=
WORKSPACE_VAULT_PATH=
DIST_PATH=dist

# Managed backend URL for agent-memory CLI / OpenClaw (see docs/INSTALLATION.md).
# AM_BACKEND_URL=https://backend.agentmemorylabs.com

# Path to a synced personal or snapshot Ladybug database (.lbug).
# Discovery fallback: HOME|USERPROFILE/.agentic-memory/*.lbug, then WORKSPACE_STORE_PATH.
LADYBUG_DB_PATH="D:\code\ladybug-lbug-file\jina-embeddings.lbug"

# Codex MCP: bearer for https://rt-c84ba9f0f933f9bb.agentmemorylabs.app/mcp-full/
# Set in the shell or OS env; referenced from ~/.codex/config.toml as AGENT_MEMORY_LADYBUG_MCP_BEARER_TOKEN.
# AGENT_MEMORY_LADYBUG_MCP_BEARER_TOKEN=

# Optional agent HTTP provider (stub today — local fallback when unset).
# AM_AGENT_PROVIDER_URL=http://127.0.0.1:8765/v1/chat
